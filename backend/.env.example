# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email (SMTP) ──────────────────────────────────────────────
# Leave blank in development — Ethereal test account is auto-created
# and preview URLs are logged to console.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=you@example.com
EMAIL_PASS=your-smtp-password
EMAIL_FROM="Enterprise NeXus" <noreply@enterprise-nexus.io>

# Address that receives escalation alert emails
ESCALATION_EMAIL=oncall@enterprise-nexus.io

# ── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── n8n Webhooks ──────────────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook
N8N_SECRET=your-n8n-webhook-secret-min-32-chars
