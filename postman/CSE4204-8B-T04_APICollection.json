                "register"
              ]
            },
            "description": "Register a new user account. Password must be 8+ chars with uppercase, number, and special character.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@nexus.io\",\n  \"password\": \"Test@1234\"\n}",
